# ===========================================
# WARBIRD ENGINE - Environment Variables
# ===========================================

# Supabase (Warbird Engine project)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Anthropic (Claude API)
ANTHROPIC_API_KEY=your-anthropic-key

# Slack Bot
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_SIGNING_SECRET=your-signing-secret
SLACK_APP_TOKEN=xapp-your-app-token

# Slack Channel IDs (Bottoms campaign)
SLACK_CHANNEL_WAR_ROOM=C0000000000
SLACK_CHANNEL_COMPETITOR_WATCH=C0000000000
SLACK_CHANNEL_CONTENT_QUEUE=C0000000000
SLACK_CHANNEL_NEWS_PULSE=C0000000000
SLACK_CHANNEL_ANALYTICS=C0000000000
SLACK_CHANNEL_REQUESTS=C0000000000

# GoHighLevel
GHL_API_KEY=your-ghl-api-key
GHL_LOCATION_ID=your-location-id

# Social Platform APIs
META_ACCESS_TOKEN=your-meta-token
META_PAGE_ID=your-page-id
INSTAGRAM_BUSINESS_ACCOUNT_ID=your-ig-business-id
TWITTER_API_KEY=your-twitter-key
TWITTER_API_SECRET=your-twitter-secret
TWITTER_ACCESS_TOKEN=your-twitter-access-token
TWITTER_ACCESS_SECRET=your-twitter-access-secret
TWITTER_BEARER_TOKEN=your-twitter-bearer-token

# Internal
WARBIRD_SERVICE_KEY=generate-a-strong-random-key
CRON_SECRET=generate-another-strong-random-key
NEXT_PUBLIC_CRON_SECRET=same-as-cron-secret-for-dashboard
NEXT_PUBLIC_APP_URL=https://your-warbird-domain.vercel.app
DEFAULT_TENANT_ID=bottoms-2026

# GoHighLevel
GHL_API_KEY=your-ghl-api-key
GHL_LOCATION_ID=your-location-id
GHL_FROM_EMAIL=scott@scottbottoms.com

# ScottBottoms Admin Webhook
SCOTTBOTTOMS_WEBHOOK_URL=https://scottbottoms.com/api/webhooks/warbird

# Paperclip Webhook
PAPERCLIP_WEBHOOK_URL=https://your-paperclip-url/warbird
